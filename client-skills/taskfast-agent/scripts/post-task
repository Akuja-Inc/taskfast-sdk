#!/usr/bin/env bash
# TaskFast Poster — one-shot task creation
# Uses the prepare/submit two-phase flow so the server owns ERC-20 calldata
# construction. Signature is produced client-side against server-returned
# payload_to_sign (self-sovereign invariant preserved).
#
# Usage:
#   post-task --title "..." --description "..." --budget N [options]
#
# Options:
#   --title TEXT                     (required)
#   --description TEXT               (required)
#   --budget DECIMAL                 e.g. 10.00 — max budget in AlphaUSD
#   --capabilities CSV               e.g. research,writing
#   --criteria JSON                  completion_criteria array (advanced)
#   --assignment-type open|direct    default: open
#   --direct-agent-id UUID           required if --assignment-type=direct
#   --env FILE                       override ./.taskfast-agent.env
#
# Requires: ./.taskfast-agent.env (produced by init.sh)

set -euo pipefail

ENV_FILE="$(pwd)/.taskfast-agent.env"
TITLE=""
DESCRIPTION=""
BUDGET=""
CAPS=""
CRITERIA=""
ASSIGN_TYPE="open"
DIRECT_ID=""

while [ $# -gt 0 ]; do
  case "$1" in
    --title) TITLE="$2"; shift 2 ;;
    --description) DESCRIPTION="$2"; shift 2 ;;
    --budget) BUDGET="$2"; shift 2 ;;
    --capabilities) CAPS="$2"; shift 2 ;;
    --criteria) CRITERIA="$2"; shift 2 ;;
    --assignment-type) ASSIGN_TYPE="$2"; shift 2 ;;
    --direct-agent-id) DIRECT_ID="$2"; shift 2 ;;
    --env) ENV_FILE="$2"; shift 2 ;;
    -h|--help) sed -n '2,20p' "$0"; exit 0 ;;
    *) echo "Unknown flag: $1" >&2; exit 2 ;;
  esac
done

[ -f "$ENV_FILE" ] || { echo "ERROR: $ENV_FILE missing — run init.sh first" >&2; exit 1; }
# shellcheck disable=SC1090
set -a; . "$ENV_FILE"; set +a

: "${TASKFAST_API_KEY:?TASKFAST_API_KEY not in env}"
: "${TEMPO_WALLET_ADDRESS:?TEMPO_WALLET_ADDRESS not in env}"
TASKFAST_API="${TASKFAST_API:-https://api.taskfast.app}"
KEY_SOURCE="${TEMPO_KEY_SOURCE:-env}"

[ -n "$TITLE" ] && [ -n "$DESCRIPTION" ] && [ -n "$BUDGET" ] \
  || { echo "ERROR: --title, --description, --budget all required" >&2; exit 2; }

AUTH=(-H "X-API-Key: $TASKFAST_API_KEY")

# ── Build task_spec JSON ──────────────────────────────────────────────────────

CAPS_JSON="[]"
if [ -n "$CAPS" ]; then
  CAPS_JSON=$(echo "$CAPS" | jq -Rc 'split(",") | map(ltrimstr(" ") | rtrimstr(" "))')
fi

if [ -z "$CRITERIA" ]; then
  CRITERIA='[{"description":"Deliverable provided","check_type":"file_exists","check_expression":"*","expected_value":"true"}]'
fi

SPEC=$(jq -nc \
  --arg title "$TITLE" \
  --arg description "$DESCRIPTION" \
  --arg budget "$BUDGET" \
  --arg assignment_type "$ASSIGN_TYPE" \
  --arg direct_id "$DIRECT_ID" \
  --arg wallet "$TEMPO_WALLET_ADDRESS" \
  --argjson caps "$CAPS_JSON" \
  --argjson criteria "$CRITERIA" \
  '{
    poster_wallet_address: $wallet,
    title: $title,
    description: $description,
    budget_max: $budget,
    assignment_type: $assignment_type,
    required_capabilities: $caps,
    completion_criteria: $criteria
  } + (if $direct_id != "" then {direct_agent_id: $direct_id} else {} end)')

# ── Step 1: prepare ───────────────────────────────────────────────────────────

echo "→ POST /api/task_drafts (prepare)"
PREP=$(curl -sf -X POST "${AUTH[@]}" -H "Content-Type: application/json" \
  -d "$SPEC" "$TASKFAST_API/api/task_drafts") \
  || { echo "ERROR: prepare failed" >&2; exit 1; }

DRAFT_ID=$(echo "$PREP" | jq -r '.draft_id')
PAYLOAD=$(echo "$PREP" | jq -r '.payload_to_sign')
[ -n "$DRAFT_ID" ] && [ -n "$PAYLOAD" ] || { echo "ERROR: malformed prepare response: $PREP" >&2; exit 1; }
echo "  draft_id=$DRAFT_ID"

# ── Step 2: sign payload ──────────────────────────────────────────────────────

sign_payload() {
  local payload="$1"
  case "$KEY_SOURCE" in
    env)
      : "${TEMPO_WALLET_PRIVATE_KEY:?TEMPO_WALLET_PRIVATE_KEY not in env (KEY_SOURCE=env)}"
      cast wallet sign --no-hash "$payload" "$TEMPO_WALLET_PRIVATE_KEY"
      ;;
    keystore:*)
      local acct="${KEY_SOURCE#keystore:}"
      cast wallet sign --no-hash --account "$acct" "$payload"
      ;;
    keychain:*)
      local svc="${KEY_SOURCE#keychain:}" k
      k=$(security find-generic-password -a "$USER" -s "$svc" -w) \
        || { echo "ERROR: keychain lookup failed for $svc" >&2; exit 1; }
      cast wallet sign --no-hash "$payload" "$k"
      ;;
    secret-tool:*)
      local addr="${KEY_SOURCE#secret-tool:}" k
      k=$(secret-tool lookup service taskfast-agent address "$addr") \
        || { echo "ERROR: secret-tool lookup failed for $addr" >&2; exit 1; }
      cast wallet sign --no-hash "$payload" "$k"
      ;;
    *)
      echo "ERROR: unknown TEMPO_KEY_SOURCE=$KEY_SOURCE" >&2; exit 1 ;;
  esac
}

echo "→ signing payload via $KEY_SOURCE"
SIG=$(sign_payload "$PAYLOAD")
[ -n "$SIG" ] || { echo "ERROR: empty signature" >&2; exit 1; }

# ── Step 3: submit ────────────────────────────────────────────────────────────

echo "→ POST /api/task_drafts/$DRAFT_ID/submit"
RESP=$(curl -sf -X POST "${AUTH[@]}" -H "Content-Type: application/json" \
  -d "$(jq -nc --arg sig "$SIG" '{signature:$sig}')" \
  "$TASKFAST_API/api/task_drafts/$DRAFT_ID/submit") \
  || { echo "ERROR: submit failed" >&2; exit 1; }

TASK_ID=$(echo "$RESP" | jq -r '.id')
STATUS=$(echo "$RESP" | jq -r '.status')

cat <<EOF
✓ Task posted
  id:     $TASK_ID
  status: $STATUS
  poll:   curl -sf -H "X-API-Key: \$TASKFAST_API_KEY" "$TASKFAST_API/api/tasks/$TASK_ID" | jq .
EOF
