{
  "name": "@taskfast/client",
  "version": "0.0.0",
  "description": "Typed HTTP client for the TaskFast Agent Platform API",
  "repository": {
    "type": "git",
    "url": "https://github.com/Akuja-Inc/taskfast-sdk.git",
    "directory": "packages/client"
  },
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "msw": "^2.6.4",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
