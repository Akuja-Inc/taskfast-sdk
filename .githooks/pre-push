#!/usr/bin/env bash
# pre-push — slow gate. Mirrors .github/workflows/ci.yml for clippy, test, doc.
#
# Opt-in full gate adds cargo-deny + cargo-audit (set TASKFAST_FULL_GATE=1).
# Kept opt-in because advisory-db flaps and the network fetch can block a push.
#
# Skip with: git push --no-verify
# Install:   ./.githooks/install.sh

set -euo pipefail

# --- BEGIN BEADS INTEGRATION v0.59.0 ---
# Chained from .beads/hooks/pre-push so beads still runs when
# core.hooksPath is pointed at .githooks (see install.sh).
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  bd hooks run pre-push "$@"
  _bd_exit=$?; if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v0.59.0 ---

cd "$(git rev-parse --show-toplevel)"

# Same env as CI — RUSTFLAGS=-D warnings keeps local behavior identical.
export RUSTFLAGS="${RUSTFLAGS:--D warnings}"
export CARGO_TERM_COLOR="${CARGO_TERM_COLOR:-always}"
export CARGO_INCREMENTAL="${CARGO_INCREMENTAL:-0}"

step() { echo; echo "pre-push: $*"; }

step "cargo clippy --workspace --all-targets --all-features --locked -- -D warnings"
cargo clippy --workspace --all-targets --all-features --locked -- -D warnings

step "cargo test --workspace --locked"
cargo test --workspace --locked

step "cargo doc --workspace --no-deps --locked (RUSTDOCFLAGS=-D warnings)"
RUSTDOCFLAGS="-D warnings" cargo doc --workspace --no-deps --locked

# Opt-in: catch supply-chain regressions (RUSTSEC / license / banned deps)
# before the push hits CI. Requires: cargo install cargo-audit cargo-deny
if [[ "${TASKFAST_FULL_GATE:-0}" == "1" ]]; then
    if command -v cargo-audit >/dev/null 2>&1; then
        step "cargo audit --deny warnings=false"
        cargo audit --deny warnings=false
    else
        echo "pre-push: TASKFAST_FULL_GATE=1 but cargo-audit not installed; skipping."
        echo "pre-push:   cargo install cargo-audit"
    fi

    if command -v cargo-deny >/dev/null 2>&1; then
        step "cargo deny check"
        cargo deny check
    else
        echo "pre-push: TASKFAST_FULL_GATE=1 but cargo-deny not installed; skipping."
        echo "pre-push:   cargo install cargo-deny"
    fi

    # Catches unused workspace deps before CI. Flags generated-code false
    # positives too — silence via [package.metadata.cargo-machete] ignored.
    if command -v cargo-machete >/dev/null 2>&1; then
        step "cargo machete"
        cargo machete
    else
        echo "pre-push: TASKFAST_FULL_GATE=1 but cargo-machete not installed; skipping."
        echo "pre-push:   cargo install cargo-machete --locked"
    fi
fi

echo
echo "pre-push: ok"
